# Trade with Tayyab — Backend Environment Configuration
#
# Copy this file to `.env` for local development and fill in real values.
# In production (Render), set these in the Render dashboard instead.

# Runtime
NODE_ENV=development
PORT=3000

# MongoDB
#   Dev  : local MongoDB instance
#   Prod : MongoDB Atlas connection string (set in Render dashboard)
MONGODB_URI=mongodb://127.0.0.1:27017/tradewithtayyab

# JWT signing secret — use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret

# Deployed frontend origin (used for CORS allow-list in production).
# localhost:3000 and localhost:5173 are always allowed for local dev.
FRONTEND_URL=https://your-frontend.vercel.app

# Cloudinary — required for admin media uploads (/api/admin/upload).
CLOUDINARY_CLOUD_NAME=dux3niyf5
CLOUDINARY_API_KEY=587493165882622
CLOUDINARY_API_SECRET=

# Server-Side Gemini AI Key (optional; falls back to canned Color Trading replies).
GEMINI_API_KEY=

# ─── WPay payment gateway (server-side only — NEVER expose in frontend) ───────
# Live merchant credentials.
WPAY_MCH_ID=2794
WPAY_SECRET_KEY=
#
# REQUIRED: the exact Payin (collection) endpoint from the WPay merchant
# dashboard (mch.wpay.one). The old hard-coded "/v1/Payin" returns 404 — it is
# NOT the real path. Set the full URL here. Until this is set, payment
# initiation returns HTTP 503 (it will NOT unlock content for free).
#   e.g. WPAY_PAYIN_URL=https://api.wpay.one/api/<Controller>/<Action>
WPAY_PAYIN_URL=
# (Alternatively set base + path instead of the full URL.)
# WPAY_API_BASE=https://api.wpay.one
# WPAY_PAYIN_PATH=/api/.../...
#
# ── Request shape overrides (only set if the dashboard spec differs) ──────────
# Field names — defaults shown. Change to match the dashboard, e.g. mchId.
# WPAY_FIELD_MCH=mch_id
# WPAY_FIELD_ORDER=out_trade_no
# WPAY_FIELD_AMOUNT=money
# WPAY_FIELD_NOTIFY=notify_url
# WPAY_FIELD_PAYTYPE=pay_type
# WPAY_FIELD_GOODS=goods_name
# WPAY_FIELD_CURRENCY=currency
# WPAY_PAY_TYPE=8001
# WPAY_CURRENCY=PKR
# WPAY_GOODS_NAME=Trade With Tayyab
# Set true if the gateway expects the amount in minor units (paisa).
# WPAY_AMOUNT_IN_CENTS=false
# Optional browser return URL after payment.
# WPAY_RETURN_URL=
# WPAY_FIELD_RETURN=return_url
#
# ── Callback shape overrides (only set if the dashboard spec differs) ─────────
# WPAY_CB_FIELD_ORDER=out_trade_no
# WPAY_CB_FIELD_AMOUNT=pay_money
# WPAY_CB_FIELD_STATUS=status
# WPAY_CB_FIELD_TXN=transaction_id
# WPAY_CB_SUCCESS_VALUE=1
