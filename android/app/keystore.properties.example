# Release signing credentials for Trade with Tayyab.
#
# 1. Copy this file to `keystore.properties` (same folder: android/app/).
# 2. Generate the keystore once with keytool, placed in this same folder.
# 3. Fill in the real values below.
#
# Paths are resolved relative to android/app/ (this module's build.gradle uses
# file(...), not rootProject.file(...)), so storeFile is just the bare filename.
#
# The real `keystore.properties` and the .jks file are gitignored — NEVER commit
# them, and BACK THEM UP. Losing the keystore means you can never ship an update
# that installs over the existing app (users would have to uninstall + reinstall).

storeFile=tradewithtayyab-release.jks
storePassword=CHANGE_ME
keyAlias=tradewithtayyab
keyPassword=CHANGE_ME
